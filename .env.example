# Finance Research Agent — environment configuration template
# Copy this file to .env and fill in real values. Never commit .env.

# ── LLM / inference server (Compatible with OpenAI/SGLang/Ollama/vLLM) ───────
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_ID=gemma4:e4b-it-q4_k_m
LLM_CONTEXT_LIMIT=32768

# ── MCP server endpoints ────────────────────────────────────────────────────
YAHOO_FINANCE_MCP_URL=http://127.0.0.1:8001
FRED_MCP_URL=http://127.0.0.1:8002
FINANCIAL_DATASETS_MCP_URL=http://127.0.0.1:8003
OPEN_WEB_SEARCH_MCP_URL=http://127.0.0.1:8004

# ── API keys for MCP tools (leave blank if not required) ───────────────────
FRED_API_KEY=
FINANCIAL_DATASETS_API_KEY=

# ── Storage ─────────────────────────────────────────────────────────────────
SQLITE_PATH=data/app.db

# ── Tool budgets ─────────────────────────────────────────────────────────────
RESEARCHER_TOOL_BUDGET=20
REVIEWER_TOOL_BUDGET=6
RETRY_TOOL_BUDGET=6

# ── RAG / embeddings (optional; uses LLM_BASE_URL for OpenAI-compatible /v1/embeddings)
# When set, retrieval can use Chroma + vectors, or in-process cosine. Leave blank for TF–IDF only.
# Ollama: use an embedding model you have pulled, e.g. `ollama pull nomic-embed-text` then set:
#   EMBEDDING_MODEL_ID=nomic-embed-text
# (HuggingFace-style ids only work if your server actually serves them at /v1/embeddings.)
EMBEDDING_MODEL_ID=nomic-embed-text
# Chunking and retrieval
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=8
RAG_MAX_CHUNKS=256
# Folder ingest: comma-separated extensions (leading dot optional)
RAG_FOLDER_EXTENSIONS=.txt,.md,.markdown,.csv,.json,.rst,.pdf
RAG_MAX_FILE_BYTES=5000000
# ChromaDB persistence directory (relative to project root unless absolute)
CHROMA_RAG_DIR=data/chroma_rag
# Use Chroma for vector search when EMBEDDING_MODEL_ID is set (true/false)
RAG_USE_CHROMA=true
# If Chroma still errors on protobuf: ensure `pip install -r requirements.txt` (protobuf 3.20.x)
# or set: PROTOCOL_BUFFERS_PYTHON_IMPLEMENTATION=python
# If logs show PostHog ``capture()`` errors from chromadb telemetry: reinstall deps (posthog<3 is pinned).

# ── Logging / debug ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG_TRACE=
